# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://user:your-password@localhost:your-port/your-database-name

# ===========================================
# JWT AUTHENTICATION
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Token expiry times
JWT_ACCESS_TOKEN_EXPIRY=your-expiry
JWT_REFRESH_TOKEN_EXPIRY=your-expiry

# Token cookie max age (in seconds)
JWT_ACCESS_TOKEN_MAX_AGE_SECONDS=your-max-age-seconds-access
JWT_REFRESH_TOKEN_MAX_AGE_SECONDS=your-max-age-refresh

# ===========================================
# SECURITY & RATE LIMITING
# ===========================================
# Rate limiter window in milliseconds 
RATE_LIMIT_WINDOW_MS=your-rate-limiter-windows

# Rate limit log retention in minutes 
RATE_LIMIT_RETENTION_MINUTES=your-limi-retention

# Idempotency key TTL in minutes 
IDEMPOTENCY_KEY_TTL_MINUTES=your-Idempotency-in-minutes

# ===========================================
# SERVER CONFIGURATION
# ===========================================
# Backend server port
BACKEND_PORT=your-port
BACKEND_URL=your-backend-url

# Request body size limit in bytes 
BODY_LIMIT_BYTES=your-limit

# Request timeout in milliseconds 
REQUEST_TIMEOUT_MS=your-timeout

# ===========================================
# CORS CONFIGURATION
# ===========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=your-cors-origins
# ===========================================
# REALTIME (SSE) CONFIGURATION
# ===========================================
# Server-Sent Events poll interval in milliseconds 
POLL_INTERVAL_MS=your-poll-interval

# ===========================================
# APP SETTINGS
# ===========================================
NEXT_PUBLIC_APP_URL=your-url
NEXT_PUBLIC_API_URL=your-app-url

# Environment
NODE_ENV=development

# ===========================================
# PAYMENT INTEGRATION (Paystack - South Africa)
# ===========================================
# Paystack is the primary payment provider for ZAR Ledger
# Sign up at: https://paystack.com

# Paystack Secret Key (from Dashboard > API Keys & Webhooks)
# Use sk_test_... for testing, sk_live_... for production
# This key is used for API calls AND webhook signature verification
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# Paystack Public Key (from Dashboard > API Keys & Webhooks)
# Use pk_test_... for testing, pk_live_... for production
# This key is used in the frontend for checkout
PAYSTACK_PUBLIC_KEY=your-paystack-public-key

# Webhook URL to configure in Paystack Dashboard:
# https://your-domain.com/api/subscription/webhook
# OR for local testing with ngrok:
# https://YOUR-NGROK-ID.ngrok.io/api/subscription/webhook
#
# NOTE: Paystack does NOT use a separate webhook secret.
# Webhook signatures are verified using your Secret Key above.

# Future payment providers (not yet implemented):
# - Peach Payments (South Africa)
# - Stripe (International)


VERCEL_TOKEN=my-vercel-token







# Paystack Webhook configuration

