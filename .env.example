# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://user:your-password@localhost:your-port/your-database-name

# ===========================================
# JWT AUTHENTICATION
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Token expiry times
JWT_ACCESS_TOKEN_EXPIRY=your-expiry
JWT_REFRESH_TOKEN_EXPIRY=your-expiry

# Token cookie max age (in seconds)
JWT_ACCESS_TOKEN_MAX_AGE_SECONDS=your-max-age-seconds-access
JWT_REFRESH_TOKEN_MAX_AGE_SECONDS=your-max-age-refresh

# ===========================================
# SECURITY & RATE LIMITING
# ===========================================
# Rate limiter window in milliseconds 
RATE_LIMIT_WINDOW_MS=your-rate-limiter-windows

# Rate limit log retention in minutes 
RATE_LIMIT_RETENTION_MINUTES=your-limi-retention

# Idempotency key TTL in minutes 
IDEMPOTENCY_KEY_TTL_MINUTES=your-Idempotency-in-minutes

# ===========================================
# SERVER CONFIGURATION
# ===========================================
# Backend server port
BACKEND_PORT=your-port
BACKEND_URL=your-backend-url

# Request body size limit in bytes 
BODY_LIMIT_BYTES=your-limit

# Request timeout in milliseconds 
REQUEST_TIMEOUT_MS=your-timeout

# ===========================================
# CORS CONFIGURATION
# ===========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=your-cors-origins
# ===========================================
# REALTIME (SSE) CONFIGURATION
# ===========================================
# Server-Sent Events poll interval in milliseconds 
POLL_INTERVAL_MS=your-poll-interval

# ===========================================
# APP SETTINGS
# ===========================================
NEXT_PUBLIC_APP_URL=your-url
NEXT_PUBLIC_API_URL=your-app-url

# Environment
NODE_ENV=development
