# ===========================================
# ZAR LEDGER - ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
#
# PRODUCTION SETUP GUIDE:
# 1. Copy this file to .env.local
# 2. Generate secure secrets (commands provided below)
# 3. Set Vercel environment variables in dashboard (recommended)
# 4. Or copy .env.local to .env.production for local testing

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
# Production: Use a managed PostgreSQL service
# Recommended providers:
# - Neon (https://neon.tech) - Serverless PostgreSQL with Vercel integration
# - Supabase (https://supabase.com) - Managed PostgreSQL with backups
# - AWS RDS (https://aws.amazon.com/rds) - Enterprise-grade
# - Vercel Postgres (https://vercel.com/postgres) - Native Vercel integration
#
# Example connection strings:
# Neon: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres?sslmode=require
# Vercel Postgres: postgres://user:password@host.vercel-pg.com:5432/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/zar_ledger

# ===========================================
# JWT AUTHENTICATION
# ===========================================
# CRITICAL: Generate a strong secret in production!
# 
# Generate using one of these commands:
#   OpenSSL: openssl rand -base64 32
#   Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   Bun: bun -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
#
# Requirements:
# - Minimum 32 characters
# - Use cryptographically secure random generation
# - Never reuse secrets across projects
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Token expiry times (production-optimized)
# Access token: 15 minutes (short-lived for security)
JWT_ACCESS_TOKEN_EXPIRY=15m
# Refresh token: 7 days (balanced UX and security)
JWT_REFRESH_TOKEN_EXPIRY=7d

# Token cookie max age (in seconds)
# Must match token expiry times above
JWT_ACCESS_TOKEN_MAX_AGE_SECONDS=900
JWT_REFRESH_TOKEN_MAX_AGE_SECONDS=604800

# ===========================================
# PII PROTECTION (POPIA Compliance)
# ===========================================
# CRITICAL: Required for hashing South African ID numbers and phone numbers
# This secret is used for HMAC-SHA256 encryption of sensitive personal data
#
# Generate using:
#   OpenSSL: openssl rand -base64 32
#   Bun: bun -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
#
# IMPORTANT: Use the same secret as JWT_SECRET or generate a new one
PII_HMAC_SECRET=your-pii-hmac-secret-change-this-in-production

# ===========================================
# SECURITY & RATE LIMITING
# ===========================================
# Rate limiter window (1 minute = 60000ms)
# Controls how many requests a user can make per window
RATE_LIMIT_WINDOW_MS=60000

# Rate limit log retention (5 minutes)
# How long to keep rate limit logs in the database
RATE_LIMIT_RETENTION_MINUTES=5

# Idempotency key TTL (24 hours = 1440 minutes)
# How long to cache idempotent request responses
IDEMPOTENCY_KEY_TTL_MINUTES=1440

# ===========================================
# SERVER CONFIGURATION
# ===========================================
# Backend server port (local development only)
BACKEND_PORT=3001

# Backend URL (for internal service communication)
# In production, this should point to your Vercel deployment
BACKEND_URL=http://localhost:3001

# Request body size limit (1MB = 1048576 bytes)
# Increase for file uploads if needed (e.g., profile pictures, receipts)
BODY_LIMIT_BYTES=1048576

# Request timeout (30 seconds = 30000ms)
# Increase for long-running operations (e.g., PDF exports, large imports)
REQUEST_TIMEOUT_MS=30000

# ===========================================
# CORS CONFIGURATION
# ===========================================
# CRITICAL: Update for production!
# Comma-separated list of allowed origins
#
# Development (localhost):
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
#
# Production (update with your domain):
# Single domain: CORS_ORIGINS=https://zarledger.co.za
# Multiple domains: CORS_ORIGINS=https://zarledger.co.za,https://www.zarledger.co.za
# With staging: CORS_ORIGINS=https://zarledger.co.za,https://staging.zarledger.co.za
#
# IMPORTANT: Do NOT include wildcards (*) when credentials are used!
# Vercel will automatically set the correct origin via environment variables

# ===========================================
# REALTIME (SSE) CONFIGURATION
# ===========================================
# Server-Sent Events poll interval (1 second = 1000ms)
# For real-time balance updates and group notifications
POLL_INTERVAL_MS=1000

# ===========================================
# APP SETTINGS
# ===========================================
# Public-facing URLs
# Update these for production!
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Environment (DO NOT CHANGE - set in Vercel dashboard for production)
NODE_ENV=development

# ===========================================
# PAYMENT INTEGRATION (Paystack - South Africa)
# ===========================================
# Paystack is the primary payment provider for ZAR Ledger
# Sign up at: https://paystack.com
#
# Testing vs Production:
# - Test keys (sk_test_*, pk_test_*): Use for development and testing
# - Live keys (sk_live_*, pk_live_*): Use for production ONLY
#
# IMPORTANT: Never commit live keys to version control!

# Paystack Secret Key (from Dashboard > API Keys & Webhooks)
# Use sk_test_... for testing, sk_live_... for production
# This key is used for API calls AND webhook signature verification
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key

# Paystack Public Key (from Dashboard > API Keys & Webhooks)
# Use pk_test_... for testing, pk_live_... for production
# This key is used in the frontend for checkout
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key

# Webhook URL to configure in Paystack Dashboard:
# Production: https://your-domain.com/api/subscription/webhook
# Local testing: https://YOUR-NGROK-ID.ngrok.io/api/subscription/webhook
#
# NOTE: Paystack does NOT use a separate webhook secret.
# Webhook signatures are verified using your Secret Key above.

# Future payment providers (not yet implemented):
# - Peach Payments (South Africa)
# - Stripe (International)

# ===========================================
# VERCEL DEPLOYMENT
# ===========================================
# Get your token from: https://vercel.com/account/tokens
# Required for GitHub Actions deployment
#
# IMPORTANT: Store these as GitHub Secrets, NOT in .env.local!
# GitHub Secrets setup:
# 1. Go to your GitHub repository > Settings > Secrets and variables > Actions
# 2. Add the following secrets:
#    - VERCEL_TOKEN: Your Vercel API token
#    - VERCEL_ORG_ID: Your Vercel organization ID
#    - VERCEL_PROJECT_ID: Your Vercel project ID
#
# Find your IDs:
# - Go to your Vercel project > Settings > General
# - Scroll to "Environment Variables" section
VERCEL_TOKEN=your-vercel-token

# Created by Vercel CLI
VERCEL_OIDC_TOKEN="your-token generated from the vercel cli"

POSTGRES_URL="your-url from from vercel"
POSTGRES_SUPABASE_SERVICE_ROLE_KEY="your sevice role key of supabase in vercel"
NEXT_PUBLIC_POSTGRES_SUPABASE_ANON_KEY="your anon key of supabase in vercel"
POSTGRES_SUPABASE_URL="your supabase url"

# These MUST be set as GitHub Secrets for CI/CD deployment
# VERCEL_ORG_ID=your-organization-id
# VERCEL_PROJECT_ID=your-project-id

# ===========================================
# CRON JOB SECURITY
# ===========================================
# Secret for verifying Vercel cron job requests
# Generate a random string and use it to verify cron endpoint calls
# Optional: Only needed if you want extra security for cron endpoints
# CRON_SECRET=your-cron-secret-optional

# ===========================================
# MONITORING & ANALYTICS (Optional)
# ===========================================
# Add these for production monitoring:

# Sentry (Error tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# Vercel Analytics (Built-in)
# Enable in Vercel dashboard: Settings > Analytics

# Log monitoring (optional for advanced setups)
# Axiom, Logtail, or Datadog integration keys

# ===========================================
# PRODUCTION CHECKLIST
# ===========================================
# Before deploying to production, ensure:
#
# [SECURITY]
# [ ] JWT_SECRET is a cryptographically secure random string (min 32 chars)
# [ ] PII_HMAC_SECRET is generated and different from JWT_SECRET
# [ ] CORS_ORIGINS only includes your production domains
# [ ] All test API keys are replaced with live keys
# [ ] .env.local is in .gitignore and NOT committed
#
# [DATABASE]
# [ ] DATABASE_URL points to a production PostgreSQL instance
# [ ] Database connection uses SSL/TLS (?sslmode=require)
# [ ] Database backups are configured (daily recommended)
# [ ] Database migrations have been run (bunx drizzle-kit migrate)
#
# [VERCEL]
# [ ] NODE_ENV=production is set in Vercel dashboard
# [ ] All environment variables are set in Vercel dashboard
# [ ] GitHub Secrets are configured for CI/CD deployment
# [ ] Vercel cron jobs are enabled for cleanup tasks
#
# [PAYMENTS]
# [ ] PAYSTACK_SECRET_KEY uses sk_live_... prefix
# [ ] PAYSTACK_PUBLIC_KEY uses pk_live_... prefix
# [ ] Webhook URL is configured in Paystack Dashboard
# [ ] Test mode is disabled in Paystack Dashboard
#
# [MONITORING]
# [ ] Vercel Analytics is enabled
# [ ] Error tracking is configured (Sentry or similar)
# [ ] Database monitoring/alerting is set up
# [ ] Uptime monitoring is configured (e.g., UptimeRobot, Pingdom)
#
# [COMPLIANCE - POPIA]
# [ ] PII data is hashed using HMAC-SHA256
# [ ] Privacy policy is published
# [ ] Data retention policies are documented
# [ ] User data export/deletion procedures are in place

# ===========================================
# LOCAL DEVELOPMENT TIPS
# ===========================================
# 1. Copy this file: cp .env.example .env.local
# 2. Install PostgreSQL locally or use a cloud provider
# 3. Run migrations: bunx drizzle-kit migrate
# 4. Start development: bun run dev:all
# 5. Access the app: http://localhost:3000
